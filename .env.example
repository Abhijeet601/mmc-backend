SECRET_KEY=replace-with-a-strong-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Supported examples:
# SQLite (local): sqlite:///./mmc.db
# PostgreSQL: postgresql+psycopg2://postgres:postgres@localhost:5432/mmc
# MySQL: mysql+pymysql://root:password@localhost:3306/mmc
DATABASE_URL=sqlite:///./mmc.db
# Railway also supports these individual variables:
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# Cloudflare R2 (required for notice file uploads)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Preferred names:
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# Backward-compatible aliases also supported:
# R2_ACCESS_KEY=your_r2_access_key_id
# R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_URL=https://<public-bucket-subdomain>.r2.dev

UPLOAD_DIR=./uploads
PHOTO_DIR=./uploads/photos
RECEIPT_DIR=./uploads/receipts
NOTICE_SOURCE_DIR=../frontend/data files/Notice
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex for deployed frontends (default in app allows any HTTPS origin).
# Example: ^https://(your-site\\.com|.*\\.vercel\\.app)$
CORS_ALLOW_ORIGIN_REGEX=^https://.+$

# Hostel ERP pricing
APP_PAYMENT_AMOUNT=1000
VAIDEHI_HOSTEL_FEE=10000
MAHIMA_HOSTEL_FEE=12000
DEMO_AUTO_APPROVE=false

# Payment provider configuration
PAYMENT_PROVIDER=demo
PAYMENT_MERCHANT_ID=496261
PAYMENT_MERCHANT_NAME=Magadh Mahila College HOSTEL (new 06 2023)
PAYMENT_MERCHANT_ROLE=MERCHANT_ADMIN
PAYMENT_MERCHANT_STATUS=ACTIVE
PAYMENT_LOGIN_PASSWORD=
PAYMENT_TRANSACTION_PASSWORD=
PAYMENT_PUBLIC_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_CALLBACK_URL=
PAYMENT_RETURN_URL=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_BANK_ACCOUNT=
PAYMENT_BANK_IFSC=
PAYMENT_BANK_BRANCH=

# Default admin bootstrapped at startup if missing
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@magadhmahilacollege.org
